{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri/next/crates/tauri-schema-generator/schemas/config.schema.json",
  "productName": "DIJA",
  "version": "1.0.0",
  "identifier": "com.dij.dija",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DIJA",
        "width": 1920,
        "height": 1080,
        "x": 0,
        "y": 0,
        "resizable": true,
        "fullscreen": false,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/meowseum/DIJA/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3QjZGRDFDRDc0NjMyQUUKUldTdU1rYlhIUDIyNSszMmdNSGlWTnAyNGpUWmg1clkvUXVKOGY4ZUlxZXBHU3R3SEVDK3o2eWsK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {}
  }
}
